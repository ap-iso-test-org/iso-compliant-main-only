{
  "name": "ISO compliant repositories - main",
  "target": "branch",
  "enforcement": "active",
  "bypass_actors": [],
  "conditions": {
    "repository_property": {
      "include": [
        {
          "name": "iso_classification",
          "property_values": [
            "iso-compliant"
          ],
          "source": "custom"
        },
        {
          "name": "branching_strategy",
          "property_values": [
            "main-only"
          ],
          "source": "custom"
        }
      ],
      "exclude": []
    },
    "ref_name": {
      "include": [
        "refs/heads/main"
      ],
      "exclude": []
    }
  },
  "rules": [
    {
      "type": "deletion"
    },
    {
      "type": "non_fast_forward"
    },
    {
      "type": "required_status_checks",
      "parameters": {
        "strict_required_status_checks_policy": true,
        "required_status_checks": [
          {
            "context": "Require exactly one release-impact label"
          }
        ]
      }
    },
    {
      "type": "pull_request",
      "parameters": {
        "required_approving_review_count": 1,
        "dismiss_stale_reviews_on_push": true,
        "require_code_owner_review": false,
        "require_last_push_approval": true,
        "required_review_thread_resolution": true,
        "allowed_merge_methods": [
          "merge",
          "squash"
        ]
      }
    }
  ]
}
